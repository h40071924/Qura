<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h2>Edit Post</h2>
    <p><%= post.id %></p>
     <h4><%= post.title %></h4>
     <form method="POST" action="/posts/<%= post.id %>?_method=PUT">
        <textarea name="content" rows="4" cols="50"><%= post.content %></textarea><br><br>
        <button type="submit">Update Post</button>
     </form>
</body>
</html>